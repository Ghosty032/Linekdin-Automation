      "parameters": {
        "jsCode": "const items = [];\n\nfor (const item of $input.all()) {\n  const text = item.json.text;\n  \n  const cleaned = text\n    .replace(/[*_`\\[\\]()~>#+=|{}.!-]/g, ' ')\n    .replace(/\\s+/g, ' ')\n    .trim();\n  \n  items.push({ json: { text: cleaned } });\n}\n\nreturn items;"
